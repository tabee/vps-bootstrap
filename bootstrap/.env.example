# =============================================================================
# .env.example — Reference for Terraform-generated .env
# =============================================================================
# This file shows the structure of .env that Terraform generates and deploys.
# DO NOT copy this file manually — use `terraform apply` instead.
#
# Terraform workflow:
#   1. Configure terraform.tfvars with your values
#   2. Run: terraform apply
#   3. Terraform generates .env from main.tf and deploys to server
#
# All variables below are set by Terraform from terraform.tfvars.
# See variables.tf for available options and defaults.
# =============================================================================

# ── Domain & DNS (from terraform.tfvars) ─────────────────────────────────────
VPN_DOMAIN="example.com"
VPN_HOSTNAME="vps"
HETZNER_API_TOKEN="<from var.hetzner_dns_token>"
ACME_EMAIL="admin@example.com"

# ── Admin User ───────────────────────────────────────────────────────────────
ADMIN_USER="admin"

# ── Service Flags ────────────────────────────────────────────────────────────
ENABLE_GITEA="false"
ENABLE_N8N="false"
ENABLE_WHOAMI="true"
ENABLE_GOGCLI="false"

# ── Service Secrets (auto-generated by Terraform) ───────────────────────────
# Only present when corresponding service is enabled
# GITEA_DB_PASSWORD="<random_password>"
# GITEA_SECRET_KEY="<random_password>"
# N8N_DB_PASSWORD="<random_password>"
# N8N_ENCRYPTION_KEY="<random_password>"

# ── VPN Clients ──────────────────────────────────────────────────────────────
VPN_CLIENTS="admin"
