# =============================================================================
# .env.example — Secrets template for VPS bootstrap
# =============================================================================
# On first run apply.sh creates .env automatically from this file:
#
#   sudo bash bootstrap/apply.sh   # auto-creates .env on first run
#
# ⚠️  Only HETZNER_API_TOKEN must be filled in manually.
#    All other secrets are auto-generated by bootstrap/init-env.sh.
#
# NEVER commit .env or wg0-client.conf to version control.
# =============================================================================

# ── Hetzner Cloud API  ⚠️  REQUIRED — fill in manually ─────────────────────
# API token with DNS zone edit permissions for your domain.
# IMPORTANT: Get token from Hetzner CLOUD Console (not old DNS Console!)
# Create at: https://console.hetzner.cloud/ → Project → Security → API Tokens
# Note: The old dns.hetzner.com tokens no longer work since 2025.
HETZNER_API_TOKEN=__HETZNER_API_TOKEN__

# ── Domain Configuration ─────────────────────────────────────────────────────
# Your domain managed by Hetzner DNS (e.g., example.com)
VPN_DOMAIN=example.com

# Server hostname (optional, defaults to 'vps')
VPN_HOSTNAME=vps

# ── ACME / Let's Encrypt ─────────────────────────────────────────────────────
# Email for Let's Encrypt certificate notifications
ACME_EMAIL=admin@example.com

# ── WireGuard  (auto-generated by init-env.sh) ───────────────────────────────
# Server private key
WG_PRIVATE_KEY=__WG_PRIVATE_KEY__

# Client private key — kept here so wg0-client.conf can be regenerated
WG_CLIENT_PRIVKEY=__WG_CLIENT_PRIVKEY__

# Client public key — installed as the WireGuard peer on the server
WG_PEER_PUBKEY=__WG_PEER_PUBKEY__

# ── Gitea / PostgreSQL  (auto-generated by init-env.sh) ─────────────────────
# PostgreSQL password for the gitea database user
DB_PASSWORD=__DB_PASSWORD__

# Gitea internal secret key
GITEA_SECRET_KEY=__GITEA_SECRET_KEY__

# Gitea internal API token
GITEA_INTERNAL_TOKEN=__GITEA_INTERNAL_TOKEN__
