# =============================================================================
# .env — VPS Bootstrap Configuration (managed by Terraform)
# =============================================================================
# DO NOT COMMIT THIS FILE — it contains secrets!
# =============================================================================

HETZNER_API_TOKEN=${hetzner_api_token}
VPN_DOMAIN=${vpn_domain}
VPN_HOSTNAME=${vpn_hostname}
ACME_EMAIL=${acme_email}

# Optional: OpenAI key for n8n workflows
OPENAI_API_KEY=${openai_api_key}

# Placeholders for auto-generated secrets (init-env.sh will replace)
WG_PRIVATE_KEY=__WG_PRIVATE_KEY__
WG_CLIENT_PRIVKEY=__WG_CLIENT_PRIVKEY__
WG_PEER_PUBKEY=__WG_PEER_PUBKEY__
DB_PASSWORD=__DB_PASSWORD__
GITEA_SECRET_KEY=__GITEA_SECRET_KEY__
GITEA_INTERNAL_TOKEN=__GITEA_INTERNAL_TOKEN__

# Optional n8n secrets (auto-generated if placeholders remain)
N8N_DB_PASSWORD=__N8N_DB_PASSWORD__
N8N_ENCRYPTION_KEY=__N8N_ENCRYPTION_KEY__
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=__N8N_BASIC_AUTH_PASSWORD__
