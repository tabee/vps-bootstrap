# =============================================================================
# .gitignore — VPS Bootstrap
# =============================================================================

# ── Secrets (NEVER commit) ──────────────────────────────────────────────────
bootstrap/.env
bootstrap/wg0-client.conf
.env
*.pem
*.key

# ── Snapshots (generated, may contain sensitive data) ───────────────────────
snapshot/*/

# ── Editor/IDE ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db