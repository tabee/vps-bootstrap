# =============================================================================
# .gitignore — VPS Bootstrap
# =============================================================================

# ── Secrets (NEVER commit) ──────────────────────────────────────────────────
bootstrap/.env
bootstrap/wg0-client.conf
.env
*.pem
*.key

# ── Terraform ───────────────────────────────────────────────────────────────
.terraform/
terraform.tfstate
terraform.tfstate.*
*.tfvars
*.log


# ── Editor/IDE ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.terraform.lock.hcl
.terraform.tfstate.lock.info
acme.json
credentials.json
