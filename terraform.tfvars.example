# =============================================================================
# VPS Bootstrap - Example Configuration
# =============================================================================
# Copy this file to terraform.tfvars and fill in your values:
#   cp terraform.tfvars.example terraform.tfvars
# =============================================================================

# ═══════════════════════════════════════════════════════════════════════════
# REQUIRED - These must be configured
# ═══════════════════════════════════════════════════════════════════════════

# Server IP from Hetzner Cloud Console
ssh_host = "123.45.67.89"

# Path to your SSH private key
ssh_private_key_path = "~/.ssh/id_ed25519"

# Your domain (DNS must point to server)
domain = "example.com"

# Hetzner DNS API token (for Let's Encrypt DNS-01 challenge)
# Get from: https://console.hetzner.cloud/ → Project → Security → API Tokens
# Note: Old dns.hetzner.com tokens no longer work since 2025
hetzner_dns_token = "your-dns-api-token"

# Email for Let's Encrypt notifications
acme_email = "admin@example.com"

# Let's Encrypt / ACME behavior
# - enabled=false  → no Let's Encrypt requests, Traefik uses its default cert
# - staging=true   → safe test mode, avoids production rate limits, certs are NOT trusted
# - require_whoami_check=true → only issue/renew after local HTTPS preflight succeeds
# - renew_before_days=30       → renew only close to expiry
letsencrypt_enabled              = true
letsencrypt_staging              = false
letsencrypt_require_whoami_check = true
letsencrypt_renew_before_days    = 30

# Path to existing acme.json from Let's Encrypt (optional)
# If set and file exists, Terraform uploads it to the server so Traefik
# reuses the certificate instead of requesting a new one.
# acme_json_path = "acme.json"

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL - Services
# ═══════════════════════════════════════════════════════════════════════════

# Git server (git.example.com)
enable_gitea = false
# gitea_admin_user     = "gitea-admin"       # Admin username
# gitea_admin_email    = "admin@example.com"  # Admin email
# gitea_admin_password = ""                   # Auto-generated if empty

# Workflow automation (n8n.example.com)
enable_n8n = false
n8n_openai_api_key = ""
# n8n_admin_email    = "admin@example.com"  # Owner email (required for login)
# n8n_admin_password = ""                   # Auto-generated if empty

# Test service (whoami.example.com)
enable_whoami = true

# Google Workspace CLI API (Docker, SSH access only)
# Requires Google OAuth setup - see docs/SERVICES.md
enable_gogcli = false

# MkDocs documentation site (docs.<domain>)
# Requires enable_gitea = true (docs live in Gitea repo)
enable_mkdocs = false
# mkdocs_webhook_secret = ""  # Auto-generated if empty

# Uptime Kuma monitoring (status.<domain>)
# Self-hosted service monitoring with web dashboard
enable_kuma = false
# kuma_admin_user     = "kuma-admin"  # Admin username
# kuma_admin_password = ""            # Auto-generated if empty

# Google OAuth credentials (optional - can be added later manually)
# Get from: https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID → Desktop app
# google_client_id     = "xxx.apps.googleusercontent.com"
# google_client_secret = "GOCSPX-xxx"
# google_project_id    = "your-project-id"

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL - VPN Clients
# ═══════════════════════════════════════════════════════════════════════════

# List of VPN clients to create
# Remove a client from this list and run `terraform apply` to delete it
vpn_clients = ["admin", "laptop", "phone"]

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL - Advanced
# ═══════════════════════════════════════════════════════════════════════════

# SSH username after hardening (default: admin)
# admin_user = "admin"

# Skip final hardening (keeps SSH accessible via public IP)
# skip_harden = false

# Server hostname
# hostname = "vps"

# ═══════════════════════════════════════════════════════════════════════════
# POST-INSTALLATION - Set after first successful deployment
# ═══════════════════════════════════════════════════════════════════════════

# After initial deployment with hardening, set this to true.
# Terraform will then connect via VPN (10.100.0.1) instead of public IP.
# use_vpn = true
